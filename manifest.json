  "shortcuts": [
    {
      "name": "Neue Bestellung",
      "short_name": "Bestellen",
      "description": "Direkt zum Menü",
      "url": "./?fresh=1&role=customer#products",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Bestellung verfolgen",
      "short_name": "Tracking",
      "description": "Aktive Bestellung live verfolgen",
      "url": "./?fresh=1#track",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Fahrer-Modus",
      "short_name": "Fahrer",
      "description": "Schnellzugang für Fahrer",
      "url": "./?fresh=1&role=driver",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Einstellungen",
      "short_name": "Settings",
      "description": "App-Einstellungen",
      "url": "./?fresh=1#settings",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "./?fresh=1#share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "prefer_related_applications": false,
  "edge_side_panel": { "preferred_width": 480 },
  "launch_handler": { "client_mode": "auto" },
  "handle_links": "preferred",
  "protocol_handlers": [
    {
      "protocol": "web+blinkgo",
      "url": "./?fresh=1&order=%s"
    }
  ],
  "version": "5.2.0"
}
